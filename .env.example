DATABASE_URL=postgresql://flowpilot:flowpilot@postgres:5432/flowpilot?schema=public
REDIS_URL=redis://redis:6379
MINIO_ROOT_USER=flowpilot
MINIO_ROOT_PASSWORD=flowpilot123
MINIO_ENDPOINT=http://minio:9000
JWT_SECRET=change-me
PORT=3001

# ─── Host ports (change if already used on your NAS) ────────────────
# Main app (Caddy reverse proxy — only port exposed to the outside)
APP_EXTERNAL_PORT=3000
# MailHog dev email (SMTP + web UI)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Synology host path where the repository and persistent data live.
# Adjust this if your project is not stored in /volume2/docker/FlowPilot.
SYNOLOGY_DATA_ROOT=/volume2/docker/FlowPilot

# Admin access (change these credentials!)
ADMIN_EMAIL=admin@flowpilot.local
ADMIN_PASSWORD=ZmenMe123456!

# ─── Internal Postgres credentials ──────────────────────────────────
# FlowPilot's Postgres runs INSIDE the Docker network and does NOT
# conflict with any Postgres you already have on your Synology. It
# creates its own isolated database in the `pgdata` Docker volume.
POSTGRES_DB=flowpilot
POSTGRES_USER=flowpilot
POSTGRES_PASSWORD=flowpilot

# SMTP (points at mailhog by default)
SMTP_HOST=mailhog
SMTP_PORT=1025

# Optional AI
# OPENAI_API_KEY=sk-...

# Optional frontend override. Leave empty behind Caddy reverse proxy.
VITE_API_URL=
