generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  ON_HOLD
}

enum BillingType {
  HOURLY
  FIXED
  RETAINER
}

enum ProjectMemberRole {
  OWNER
  MEMBER
  VIEWER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DependencyType {
  BLOCKS
  BLOCKED_BY
  RELATES_TO
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CARD
  OTHER
}

// ============== MODELS ==============

model Client {
  id                     String    @id @default(uuid()) @db.Uuid
  name                   String
  ic                     String?   // IČO
  dic                    String?   // DIČ
  isCompany              Boolean   @default(true)
  email                  String?
  phone                  String?
  website                String?
  billingAddress         Json?
  deliveryAddress        Json?
  note                   String?
  defaultPaymentTermsDays Int      @default(14)
  defaultInvoiceNote     String?
  vatSubject             Boolean   @default(false)
  country                String    @default("CZ")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?
  contacts               Contact[]
  projects               Project[]
  invoices               Invoice[]

  @@map("clients")
}

model Contact {
  id        String  @id @default(uuid()) @db.Uuid
  clientId  String  @db.Uuid
  client    Client  @relation(fields: [clientId], references: [id])
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean @default(false)

  @@map("contacts")
}

model BankAccount {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  bankName      String?
  accountNumber String
  iban          String?
  swift         String?
  currency      String    @default("CZK")
  isDefault     Boolean   @default(false)
  isActive      Boolean   @default(true)
  invoices      Invoice[]

  @@map("bank_accounts")
}

model Product {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  description        String?
  unit               String   @default("hod")
  defaultUnitPrice   Decimal  @default(0) @db.Decimal(10, 2)
  defaultVatPercent  Decimal  @default(0) @db.Decimal(5, 2)
  category           String?
  isActive           Boolean  @default(true)

  @@map("products")
}

model Invoice {
  id               String            @id @default(uuid()) @db.Uuid
  invoiceNumber    String            @unique
  clientId         String            @db.Uuid
  client           Client            @relation(fields: [clientId], references: [id])
  projectId        String?           @db.Uuid
  project          Project?          @relation(fields: [projectId], references: [id])
  bankAccountId    String?           @db.Uuid
  bankAccount      BankAccount?      @relation(fields: [bankAccountId], references: [id])
  status           InvoiceStatus     @default(DRAFT)
  issueDate        DateTime          @default(now())
  dueDate          DateTime
  taxPointDate     DateTime?
  currency         String            @default("CZK")
  exchangeRate     Decimal           @default(1) @db.Decimal(10, 4)
  subtotal         Decimal           @default(0) @db.Decimal(10, 2)
  discountPercent  Decimal           @default(0) @db.Decimal(5, 2)
  discountAmount   Decimal           @default(0) @db.Decimal(10, 2)
  vatPercent       Decimal           @default(0) @db.Decimal(5, 2)
  vatAmount        Decimal           @default(0) @db.Decimal(10, 2)
  total            Decimal           @default(0) @db.Decimal(10, 2)
  totalPaid        Decimal           @default(0) @db.Decimal(10, 2)
  paymentMethod    PaymentMethod     @default(BANK_TRANSFER)
  qrCodeData       String?
  note             String?
  footerNote       String?
  pdfPath          String?
  sentAt           DateTime?
  paidAt           DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lineItems        InvoiceLineItem[]
  timeEntries      TimeEntry[]

  @@map("invoices")
}

model InvoiceLineItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @db.Uuid
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taskId      String?  @db.Uuid
  task        Task?    @relation(fields: [taskId], references: [id])
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unit        String   @default("hod")
  unitPrice   Decimal  @default(0) @db.Decimal(10, 2)
  vatPercent  Decimal  @default(0) @db.Decimal(5, 2)
  total       Decimal  @default(0) @db.Decimal(10, 2)
  sortOrder   Int      @default(0)

  @@map("invoice_line_items")
}

model InvoiceNumberSequence {
  id         String @id @default(uuid()) @db.Uuid
  prefix     String @default("FP")
  year       Int
  lastNumber Int    @default(0)

  @@unique([prefix, year])
  @@map("invoice_number_sequences")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         UserRole @default(MEMBER)
  avatarUrl    String?  @map("avatar_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectMemberships ProjectMember[]
  assignedTasks      Task[]          @relation("TaskAssignee")
  reportedTasks      Task[]          @relation("TaskReporter")
  timeEntries        TimeEntry[]

  @@map("users")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  clientId    String?  @map("client_id") @db.Uuid
  status      ProjectStatus @default(ACTIVE)
  billingType BillingType   @default(HOURLY)

  budgetHours         Float?    @map("budget_hours")
  budgetAmount        Decimal?  @map("budget_amount") @db.Decimal(12, 2)
  hourlyRateDefault   Decimal?  @map("hourly_rate_default") @db.Decimal(10, 2)

  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  tags        Json  @default("[]")
  description String?

  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     ProjectMember[]
  tasks       Task[]
  timeEntries TimeEntry[]
  client      Client?    @relation(fields: [clientId], references: [id])
  invoices    Invoice[]

  @@map("projects")
}

model ProjectMember {
  userId    String @map("user_id")
  projectId String @map("project_id")
  role      ProjectMemberRole @default(MEMBER)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@map("project_members")
}

model Task {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  parentTaskId String? @map("parent_task_id")

  name        String
  description String?

  status   TaskStatus   @default(TODO)
  priority TaskPriority @default(NONE)

  assigneeId String? @map("assignee_id")
  reporterId String? @map("reporter_id")

  estimatedHours Float? @map("estimated_hours")
  dueDate        DateTime? @map("due_date")
  startDate      DateTime? @map("start_date")

  trackTime  Boolean @default(true)
  billingType BillingType? @map("billing_type")
  workTypeId String? @map("work_type_id")

  position Int @default(0)

  labels       Json @default("[]")
  customFields Json @default("{}")

  doneAt DateTime? @map("done_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTask    Task?          @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks    Task[]         @relation("TaskHierarchy")
  assignee      User?          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter      User?          @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  workType      WorkType?      @relation(fields: [workTypeId], references: [id], onDelete: SetNull)
  timeEntries   TimeEntry[]
  dependencies  TaskDependency[] @relation("TaskDependency")
  dependents    TaskDependency[] @relation("TaskDependent")
  invoiceLineItems InvoiceLineItem[]

  @@map("tasks")
}

model TaskDependency {
  taskId     String @map("task_id")
  dependsOnId String @map("depends_on_id")
  type       DependencyType @default(BLOCKS)

  task      Task @relation("TaskDependency", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependent", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@id([taskId, dependsOnId])
  @@map("task_dependencies")
}

model TimeEntry {
  id          String  @id @default(uuid())
  taskId      String? @map("task_id")
  projectId   String  @map("project_id")
  userId      String  @map("user_id")
  workTypeId  String? @map("work_type_id")
  invoiceId   String? @map("invoice_id")

  description String?

  startedAt DateTime @map("started_at")
  endedAt   DateTime? @map("ended_at")
  durationMinutes Int? @map("duration_minutes")
  billingAmount Decimal? @map("billing_amount") @db.Decimal(12, 2)

  isBillable Boolean @default(true) @map("is_billable")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workType WorkType? @relation(fields: [workTypeId], references: [id], onDelete: SetNull)
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@map("time_entries")
}

model WorkType {
  id         String  @id @default(uuid())
  name       String
  hourlyRate Decimal @map("hourly_rate") @db.Decimal(10, 2)
  color      String
  isActive   Boolean @default(true) @map("is_active")

  tasks       Task[]
  timeEntries TimeEntry[]

  @@map("work_types")
}

model Setting {
  id    String          @id @default(uuid())
  key   String          @unique
  value String
  type  SettingValueType @default(STRING)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
